{
  "calculateCctDate": [
    {
      "description": "LTFT single change uses PM endDate when change endDate is absent",
      "input": {
        "programmeMembership": {
          "id": "11111111-1111-1111-1111-111111111111",
          "name": "Test Programme",
          "startDate": "2025-01-01",
          "endDate": "2025-12-31",
          "wte": 1
        },
        "changes": [
          {
            "id": "21111111-1111-1111-1111-111111111111",
            "type": "LTFT",
            "startDate": "2025-08-01",
            "wte": 0.5
          }
        ]
      },
      "expected": "2026-03-18"
    },
    {
      "description": "LTFT single change uses explicit change endDate when present",
      "input": {
        "programmeMembership": {
          "id": "11111111-1111-1111-1111-111111111112",
          "name": "Test Programme",
          "startDate": "2020-01-01",
