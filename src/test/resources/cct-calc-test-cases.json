            "endDate": "2025-06-30",
            "wte": 1
          }
        ]
      },
      "expected": "2025-06-30"
    },
    {
      "description": "LTFT same start and end date counts as one change day",
      "input": {
        "programmeMembership": {
          "id": "11111111-1111-1111-1111-111111111114",
          "name": "Test Programme",
          "startDate": "2025-01-01",
