          "wte": 1
        },
        "changes": [
          {
            "id": "21111111-1111-1111-1111-111111111112",
            "type": "LTFT",
            "startDate": "2025-10-01",
            "endDate": "2026-03-31",
            "wte": 0.8
          }
        ]
      },
      "expected": "2028-02-06"
    },
    {
      "description": "LTFT 100% WTE edge case does not extend CCT date",
      "input": {
        "programmeMembership": {
          "id": "11111111-1111-1111-1111-111111111113",
          "name": "Test Programme",
          "startDate": "2025-01-01",
          "endDate": "2025-06-30",
